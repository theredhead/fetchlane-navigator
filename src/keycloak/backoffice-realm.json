{
  "realm": "backoffice",
  "enabled": true,
  "displayName": "Fetchlane Navigator",
  "accountTheme": "keycloak.v3",
  "requiredCredentials": ["password"],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access to all tables and CRUD operations"
      },
      {
        "name": "guest",
        "description": "Read-only access to all tables except Customer"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@theredhead.nl",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"],
      "clientRoles": {
        "account": ["manage-account", "view-profile"]
      }
    },
    {
      "username": "guest",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Guest",
      "lastName": "User",
      "email": "guest@theredhead.nl",
      "credentials": [
        {
          "type": "password",
          "value": "guest",
          "temporary": false
        }
      ],
      "realmRoles": ["guest"],
      "clientRoles": {
        "account": ["manage-account", "view-profile"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "fetchlane-api",
      "name": "Fetchlane API",
      "description": "Bearer-only client for Fetchlane backend token validation",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "backoffice-app",
      "name": "Fetchlane Navigator App",
      "description": "Public SPA client with PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "fetchlane-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fetchlane-api",
            "id.token.claim": "false",
            "lightweight.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
