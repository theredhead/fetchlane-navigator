# Path to the Fetchlane source repository (used to build the Fetchlane image)
FETCHLANE_REPO_PATH=

# Keycloak bootstrap admin credentials
KC_BOOTSTRAP_ADMIN_USERNAME=
KC_BOOTSTRAP_ADMIN_PASSWORD=

# PostgreSQL credentials
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# MySQL credentials
MYSQL_ROOT_PASSWORD=

# SQL Server credentials
SA_PASSWORD=

# Fetchlane OIDC issuer (shared by all three Fetchlane instances)
FETCHLANE_OIDC_ISSUER_URL=
